# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/.next-e2e-billing/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/data/*.db
/data/*.db-wal
/data/*.db-shm
/data/**/*.db
/data/**/*.db-wal
/data/**/*.db-shm
/data/**/*outbox.json
/data/focus-collector/
/.sqlite.db
/.sqlite.db-wal
/.sqlite.db-shm

# test results
/test-results/
/playwright-report/

# handoff (cross-session temp file)
HANDOFF.md

# claude code local settings
.claude/settings.local.json
.claude/

# git worktrees (isolated workspaces)
.worktrees/

# RAG eval — keep ground-truth.json，忽略具体跑分结果（可能含 chunk 内容）
/eval/results/
/.backfill-milvus-failed.json

# learning migration: local config (per-user) and prod dumps stay local
/scripts/migrate-config*.json
/backups/