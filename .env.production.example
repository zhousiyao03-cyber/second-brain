# Canonical public hostname and optional apex redirect used by Caddy.
APP_DOMAIN=www.knosi.example.com
ROOT_DOMAIN=knosi.example.com
# Optional ACME contact email if you want Caddy's certificate notices sent to an inbox.
ACME_EMAIL=ops@example.com

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me
AUTH_TRUST_HOST=true
# Required for OAuth callbacks behind a reverse proxy.
AUTH_URL=https://www.knosi.example.com

# Choose one database strategy:
# 1. Keep Turso during the first migration wave:
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token
#
# 2. Or switch to local SQLite on the server:
# TURSO_DATABASE_URL=file:/app/data/second-brain.db

# Server-triggered job endpoints.
CRON_SECRET=replace-with-random-hex
JOBS_TICK_TOKEN=replace-with-random-hex
OPS_OWNER_EMAIL=you@example.com

# AI provider. Adjust to your setup.
AI_PROVIDER=codex
AI_DAILY_LIMIT=50

# Optional Redis override. By default docker-compose.prod.yml points at the
# bundled redis service.
# REDIS_URL=redis://redis:6379

# Optional: S3-compatible image uploads for self-hosting.
S3_ENDPOINT=https://s3.example.com
S3_REGION=auto
S3_BUCKET=knosi-assets
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_BASE_URL=https://assets.example.com
# S3_FORCE_PATH_STYLE=true

# Optional OAuth providers.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional feature flags.
ENABLE_TOKEN_USAGE=false
NEXT_PUBLIC_ENABLE_TOKEN_USAGE=false
ENABLE_PORTFOLIO=false
NEXT_PUBLIC_ENABLE_PORTFOLIO=false
ENABLE_OSS_PROJECTS=false
NEXT_PUBLIC_ENABLE_OSS_PROJECTS=false
ENABLE_FOCUS_TRACKER=false
NEXT_PUBLIC_ENABLE_FOCUS_TRACKER=false
