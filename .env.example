# ── 数据库 ──────────────────────────────────────────
# 生产环境（Turso）
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# 本地开发（本地 SQLite 文件，不需要 auth token）
# TURSO_DATABASE_URL=file:data/second-brain.db

# Default: OpenClaw / Codex OAuth (no API key)
AI_PROVIDER=codex

# Optional: these defaults already match a standard OpenClaw setup
# CODEX_AUTH_STORE_PATH=/Users/yourname/.openclaw/agents/main/agent/auth-profiles.json
# CODEX_AUTH_PROFILE_ID=openai-codex:default
# CODEX_MODEL=gpt-5.4
# CODEX_CHAT_MODEL=gpt-5.4
# CODEX_TASK_MODEL=gpt-5.4
# Optional: enable semantic retrieval for Ask AI
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: standard OpenAI API key route
# AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.4
# OPENAI_CHAT_MODEL=gpt-5.4
# OPENAI_TASK_MODEL=gpt-5.4
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: local OpenAI-compatible runtime (Ollama / LM Studio / vLLM)
# AI_PROVIDER=local
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_MODEL=qwen2.5:14b
# AI_CHAT_MODEL=qwen2.5:14b
# AI_TASK_MODEL=qwen2.5:14b
# AI_EMBEDDING_MODEL=nomic-embed-text
# AI_API_KEY=local
