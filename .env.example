# ── 数据库 ──────────────────────────────────────────
# 生产环境（Turso）
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# 本地开发（本地 SQLite 文件，不需要 auth token）
# TURSO_DATABASE_URL=file:data/second-brain.db

# Default: OpenClaw / Codex OAuth (no API key)
AI_PROVIDER=codex

# Optional: these defaults already match a standard OpenClaw setup
# CODEX_AUTH_STORE_PATH=/Users/yourname/.openclaw/agents/main/agent/auth-profiles.json
# CODEX_AUTH_PROFILE_ID=openai-codex:default
# CODEX_MODEL=gpt-5.4
# CODEX_CHAT_MODEL=gpt-5.4
# CODEX_TASK_MODEL=gpt-5.4
# Optional: enable semantic retrieval for Ask AI
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Portfolio news source
# MARKETAUX_API_KEY=your-marketaux-api-key

# Optional: standard OpenAI API key route
# AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.4
# OPENAI_CHAT_MODEL=gpt-5.4
# OPENAI_TASK_MODEL=gpt-5.4
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: local OpenAI-compatible runtime (Ollama / LM Studio / vLLM)
# AI_PROVIDER=local
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_MODEL=qwen2.5:14b
# AI_CHAT_MODEL=qwen2.5:14b
# AI_TASK_MODEL=qwen2.5:14b
# AI_EMBEDDING_MODEL=nomic-embed-text
# AI_API_KEY=local

# Optional: Ask AI daemon mode — route chat through a local Claude Code daemon
# When set, POST /api/chat enqueues to chat_tasks and the local
# usage daemon (pnpm usage:daemon) spawns `claude -p` using your
# local Claude subscription. Requires `claude login` to have run.
# AI_PROVIDER=claude-code-daemon
# CLAUDE_CODE_CHAT_MODEL=opus    # "opus" | "sonnet" | "haiku" | full model id

# ── 认证（Auth.js） ─────────────────────────────────
AUTH_SECRET=your-auth-secret              # openssl rand -base64 32
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Focus collector ingestion（个人部署可选）
# FOCUS_INGEST_API_KEY=your-focus-ingest-api-key
# FOCUS_INGEST_USER_ID=your-user-id

# Optional: S3-compatible image uploads for self-hosted note assets
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=auto
# S3_BUCKET=knosi-assets
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_PUBLIC_BASE_URL=https://assets.example.com
# S3_FORCE_PATH_STYLE=true

# ── AI 速率限制 ──────────────────────────────────────
AI_DAILY_LIMIT=50                         # 每用户每天 AI 调用上限（0 = 无限制）

# ── 功能开关 ──────────────────────────────────────────
ENABLE_TOKEN_USAGE=false
NEXT_PUBLIC_ENABLE_TOKEN_USAGE=false
ENABLE_PORTFOLIO=false
NEXT_PUBLIC_ENABLE_PORTFOLIO=false
ENABLE_OSS_PROJECTS=false
NEXT_PUBLIC_ENABLE_OSS_PROJECTS=false
ENABLE_FOCUS_TRACKER=false
NEXT_PUBLIC_ENABLE_FOCUS_TRACKER=false

# ── Billing (hosted knosi.xyz only — leave unset for self-hosting) ──
KNOSI_HOSTED_MODE=false
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_ANNUAL=

# Knosi-hosted Pro AI (Codex account pool, comma-separated)
KNOSI_HOSTED_AI_PROVIDER=codex
KNOSI_CODEX_ACCOUNT_POOL=

# One-time grandfather: users with createdAt < launch get 30 days of Pro at launch.
# Set to ISO date on the day billing ships; leave unset before launch.
KNOSI_BILLING_LAUNCH_DATE=
